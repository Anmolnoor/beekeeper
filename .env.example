BEEKEEPER_LLM_PROVIDER=ollama
# Optional: comma-separated providers for fallback (e.g. ollama,gemini)
# BEEKEEPER_LLM_PROVIDERS=ollama,gemini
BEEKEEPER_OLLAMA_BASE_URL=http://100.99.106.59:11434
BEEKEEPER_OLLAMA_MODEL=catsarethebest/qwen2.5-N2:1.5b
# Optional: model scoping per tier (economy/standard/premium) - fallback to BEEKEEPER_OLLAMA_MODEL
# BEEKEEPER_OLLAMA_MODEL_ECONOMY=
# BEEKEEPER_OLLAMA_MODEL_STANDARD=
# BEEKEEPER_OLLAMA_MODEL_PREMIUM=
BEEKEEPER_OLLAMA_TIMEOUT_SECONDS=120
BEEKEEPER_GEMINI_API_KEY=
BEEKEEPER_GEMINI_MODEL=gemini-1.5-flash
# Optional: model scoping per tier
# BEEKEEPER_GEMINI_MODEL_ECONOMY=
# BEEKEEPER_GEMINI_MODEL_PREMIUM=
BEEKEEPER_GEMINI_TIMEOUT_SECONDS=120
# OpenAI (optional - use in BEEKEEPER_LLM_PROVIDERS=ollama,openai)
BEEKEEPER_OPENAI_API_KEY=
BEEKEEPER_OPENAI_MODEL=gpt-4o-mini
BEEKEEPER_OPENAI_BASE_URL=
BEEKEEPER_OPENAI_TIMEOUT_SECONDS=120
BEEKEEPER_CELERY_BROKER_URL=redis://localhost:6379/0
BEEKEEPER_CELERY_BACKEND_URL=redis://localhost:6379/1
BEEKEEPER_VECTOR_BACKEND=qdrant
BEEKEEPER_VECTOR_URL=http://localhost:6333
# Split SearXNG URLs by runtime to avoid localhost leakage inside Docker containers.
BEEKEEPER_SEARXNG_BASE_URL_LOCAL=http://localhost:8080
BEEKEEPER_SEARXNG_BASE_URL_DOCKER=http://searxng:8080
# Legacy fallback (still supported; prefer *_LOCAL / *_DOCKER above)
BEEKEEPER_SEARXNG_BASE_URL=http://localhost:8080
BEEKEEPER_TEMPORAL_ENDPOINT=localhost:7233
BEEKEEPER_TEMPORAL_ENDPOINT_FALLBACKS=temporal:7233,localhost:7233,host.docker.internal:7233
BEEKEEPER_TEMPORAL_NAMESPACE=default
BEEKEEPER_TEMPORAL_TASK_QUEUE=beekeeper-queue
BEEKEEPER_STORE_ROOT=.beekeeper_store
BEEKEEPER_HONEYCOMB_ROOT=/Users/anmolnoor/Developer/agent/.honeycomb
BEEKEEPER_AUDIT_SIGNING_KEY=beekeeper-dev-signing-key

# WhatsApp (optional - use env or configure via POST /api/channels/whatsapp)
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_APP_SECRET=
WHATSAPP_VERIFY_TOKEN=

# MCP servers (optional - tools from external MCP servers via stdio or HTTP)
# Single server: BEEKEEPER_MCP_SERVERS=stdio:npx:-y:@modelcontextprotocol/server-filesystem
# Or HTTP: BEEKEEPER_MCP_SERVERS=http:https://example.com/mcp
# Multiple servers: BEEKEEPER_MCP_SERVERS_JSON=[{"transport":"stdio","command":"npx","args":["-y","@modelcontextprotocol/server-filesystem"]}]
# BEEKEEPER_MCP_SERVERS=
# BEEKEEPER_MCP_SERVERS_JSON=
