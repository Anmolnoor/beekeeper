BEEHIVE_LLM_PROVIDER=ollama
# Optional: comma-separated providers for fallback (e.g. ollama,gemini)
# BEEHIVE_LLM_PROVIDERS=ollama,gemini
BEEHIVE_OLLAMA_BASE_URL=http://100.99.106.59:11434
BEEHIVE_OLLAMA_MODEL=catsarethebest/qwen2.5-N2:1.5b
# Optional: model scoping per tier (economy/standard/premium) - fallback to BEEHIVE_OLLAMA_MODEL
# BEEHIVE_OLLAMA_MODEL_ECONOMY=
# BEEHIVE_OLLAMA_MODEL_STANDARD=
# BEEHIVE_OLLAMA_MODEL_PREMIUM=
BEEHIVE_OLLAMA_TIMEOUT_SECONDS=120
BEEHIVE_GEMINI_API_KEY=
BEEHIVE_GEMINI_MODEL=gemini-1.5-flash
# Optional: model scoping per tier
# BEEHIVE_GEMINI_MODEL_ECONOMY=
# BEEHIVE_GEMINI_MODEL_PREMIUM=
BEEHIVE_GEMINI_TIMEOUT_SECONDS=120
# OpenAI (optional - use in BEEHIVE_LLM_PROVIDERS=ollama,openai)
BEEHIVE_OPENAI_API_KEY=
BEEHIVE_OPENAI_MODEL=gpt-4o-mini
BEEHIVE_OPENAI_BASE_URL=
BEEHIVE_OPENAI_TIMEOUT_SECONDS=120
BEEHIVE_CELERY_BROKER_URL=redis://localhost:6379/0
BEEHIVE_CELERY_BACKEND_URL=redis://localhost:6379/1
BEEHIVE_VECTOR_BACKEND=qdrant
BEEHIVE_VECTOR_URL=http://localhost:6333
BEEHIVE_SEARXNG_BASE_URL=http://localhost:8080
BEEHIVE_TEMPORAL_ENDPOINT=localhost:7233
BEEHIVE_TEMPORAL_ENDPOINT_FALLBACKS=temporal:7233,localhost:7233,host.docker.internal:7233
BEEHIVE_TEMPORAL_NAMESPACE=default
BEEHIVE_TEMPORAL_TASK_QUEUE=beehive-queue
BEEKEEPER_STORE_ROOT=.beekeeper_store
BEEKEEPER_AUDIT_SIGNING_KEY=beekeeper-dev-signing-key

# WhatsApp (optional - use env or configure via POST /api/channels/whatsapp)
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_APP_SECRET=
WHATSAPP_VERIFY_TOKEN=
